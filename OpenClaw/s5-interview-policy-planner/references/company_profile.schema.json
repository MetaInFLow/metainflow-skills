{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CompanyProfile",
  "type": "object",
  "required": [
    "excel_context",
    "transcript_facts",
    "conflicts",
    "minutes_summary",
    "match_summary",
    "missing_fields",
    "risk_flags",
    "evidence"
  ],
  "properties": {
    "excel_context": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "value",
          "status",
          "confidence",
          "evidence"
        ],
        "properties": {
          "value": {},
          "status": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          },
          "label": {
            "type": "string"
          },
          "cell": {
            "type": "string"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "source",
                "text"
              ],
              "properties": {
                "source": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "transcript_facts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "value",
          "status",
          "confidence",
          "evidence"
        ],
        "properties": {
          "value": {},
          "status": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "source",
                "text"
              ],
              "properties": {
                "source": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "label",
          "reason"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "cell": {
            "type": "string"
          },
          "excel_value": {},
          "transcript_value": {},
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "minutes_summary": {
      "type": "object",
      "required": [
        "text",
        "items"
      ],
      "properties": {
        "text": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "label",
              "value"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "match_summary": {
      "type": "object",
      "required": [
        "text",
        "items",
        "selected_policy_count",
        "eligible_count",
        "conditional_count",
        "insufficient_evidence_count"
      ],
      "properties": {
        "text": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "label",
              "value"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "selected_policy_count": {
          "type": "integer"
        },
        "eligible_count": {
          "type": "integer"
        },
        "conditional_count": {
          "type": "integer"
        },
        "insufficient_evidence_count": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "severity",
          "reason"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "text"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
